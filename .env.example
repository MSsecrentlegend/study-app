# Environment Variables

# Vercel Blob Storage (automatically set by Vercel)
# BLOB_READ_WRITE_TOKEN=your_token_here

# Admin Token for API authentication
# Generate a secure random token and keep it secret
ADMIN_TOKEN=your_secure_random_token_here

# Upload endpoint (for cloud storage)
# Set to your Vercel domain when deployed
NEXT_PUBLIC_UPLOAD_ENDPOINT=/api/upload

# Feature flags
NEXT_PUBLIC_USE_CLOUD_STORAGE=false
NEXT_PUBLIC_MAX_FILE_SIZE=104857600
NEXT_PUBLIC_MAX_VIDEO_SIZE=5368709120
